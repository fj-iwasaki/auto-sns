# Google AI Studio (https://aistudio.google.com/app/apikey) — 無料枠で利用可
GEMINI_API_KEY=your_gemini_key_here

# Teams Workflows アプリの "Post to a chat when a webhook request is received"
# テンプレートで発行される HTTP URL（末尾に &sig=... を含むもの）
TEAMS_WEBHOOK_URL=https://default-XXXXX.environment.api.powerplatform.com:443/.../invoke?api-version=1&sp=%2Ftriggers%2Fmanual%2Frun&sv=1.0&sig=XXXXXXXX

# 任意: Nitterインスタンス（公開インスタンスは不安定、空なら自動でX収集をスキップ）
NITTER_INSTANCES=https://nitter.net,https://nitter.privacydev.net

# 任意: 1回に要約に渡す最大記事数（無料枠の節約用）
MAX_ITEMS=15
